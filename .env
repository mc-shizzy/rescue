# ===========================================
# HANDYFLIX Authentication Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# MongoDB Atlas Connection String
# Get this from: https://cloud.mongodb.com -> Connect -> Drivers
MONGODB_URI=mongodb+srv://shizxyandy_db_user:CzW6IhRRaRUzxiIN@cluster0.uos1nyb.mongodb.net/?appName=Cluster0

# NextAuth.js Configuration
# Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-key-at-least-32-characters
NEXTAUTH_URL=http://localhost:8000

# Google OAuth (Optional but recommended)
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
